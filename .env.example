# Bitget API (competition sub-account — only needed for live execution)
BITGET_API_BASE_URL=https://api.bitget.com
BITGET_TIMEOUT_MS=30000
BITGET_RETRIES=3
BITGET_API_KEY=
BITGET_SECRET_KEY=
BITGET_PASSPHRASE=

# LLM — use hackathon Qwen key from your registration email
LLM_PROVIDER=qwen
LLM_API_KEY=
LLM_BASE_URL=https://hackathon.bitgetops.com/v1
LLM_MODEL=qwen3.6-plus

# Market perception (optional — news channel stays neutral without it)
EXA_API_KEY=

# Signal profile: balanced | momentum | contrarian | sol-alpha
SIGNAL_PROFILE=balanced

# Agent behaviour
AGENT_SYMBOL=BTCUSDT
AGENT_PRODUCT_TYPE=USDT-FUTURES
AGENT_INTERVAL_MS=300000
AGENT_MAX_NOTIONAL_USDT=100
AGENT_MAX_LEVERAGE=5
AGENT_DRY_RUN=true

# Demo API + dashboard
PORT=4100
